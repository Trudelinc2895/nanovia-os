# ============================================================
# Nanovia OS — .env.example
# cp .env.example .env  →  remplir les vraies valeurs
# JAMAIS committer .env
# ============================================================

# APP
APP_ENV=development                        # development | staging | production
APP_NAME=Nanovia OS
APP_VERSION=1.0.0
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR | CRITICAL

# DOMAIN
DOMAIN=nanovia.ca
ACME_EMAIL=admin@nanovia.ca
PUBLIC_IP=REPLACE_ME_PUBLIC_IP

# PORTS
API_PORT=8010
ADMIN_PORT=3020
WEB_PORT=3000
AI_ORCHESTRATOR_PORT=8020

# URLS (no trailing slash)
API_BASE_URL=http://127.0.0.1:8010
# Leave empty in production to use same-origin /api behind the reverse proxy.
NEXT_PUBLIC_API_URL=
PUBLIC_WEB_URL=http://localhost:3000       # Used for Stripe redirects and email links
PRIVATE_ADMIN_URL=http://localhost:3020

# DATABASE
# Dev SQLite:   sqlite+aiosqlite:///./dev.db
# Prod Postgres: postgresql+psycopg://user:pass@host:5432/dbname
POSTGRES_DB=ktmonetization
POSTGRES_USER=ktadmin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_32CHAR+
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# REDIS
# Generate password: openssl rand -hex 32
REDIS_PASSWORD=GENERATE_WITH_openssl_rand_hex_32
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
# Dev (no auth): REDIS_URL=redis://localhost:6379/0

# VAULT
SECRET_PROVIDER=auto                        # env | auto | vault
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=CHANGE_ME
VAULT_REQUEST_TIMEOUT_SECONDS=5.0

# JWT (min 32 chars — use: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE_ME_256BIT_RANDOM_32CHARS_MINIMUM
JWT_SECRET_KEY_REF=
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ISSUER=nanovia
JWT_AUDIENCE=nanovia-users

# STRIPE (TEST → remplacer sk_test_ par sk_live_ en prod)
# Générer les price IDs via: python stripe/setup_stripe.py
STRIPE_PUBLIC_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_SECRET_KEY_REF=
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_WEBHOOK_SECRET_REF=

# Subscription prices (monthly + yearly)
STRIPE_PRICE_PRO_MONTHLY_ID=price_REPLACE_ME
STRIPE_PRICE_PRO_YEARLY_ID=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_MONTHLY_ID=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_YEARLY_ID=price_REPLACE_ME

# One-time purchases
STRIPE_CREDIT_PRICE_ID=price_REPLACE_ME          # credit pack (one-time)
STRIPE_CREDIT_PACK_SIZE=100                        # credits per pack

# Add-ons (one-time)
STRIPE_PRICE_ADDON_API_PACK=price_REPLACE_ME       # +500 API calls ($5)
STRIPE_PRICE_ADDON_STORAGE_10GB=price_REPLACE_ME   # +10 GB storage ($5)
STRIPE_PRICE_CREDITS_PACK=price_REPLACE_ME         # +50 credits ($4)

# Per-module à-la-carte subscriptions (monthly recurring)
# Run: python stripe/setup_stripe.py  →  copies these IDs
STRIPE_PRICE_MODULE_OPERATOR=price_REPLACE_ME      # AI Operator ($19/mo)
STRIPE_PRICE_MODULE_CONTENT=price_REPLACE_ME       # Content Cloner ($15/mo)
STRIPE_PRICE_MODULE_MICRO_SAAS=price_REPLACE_ME    # Micro-SaaS Builder ($29/mo)
STRIPE_PRICE_MODULE_GHOST=price_REPLACE_ME         # Ghost Agency ($39/mo)
STRIPE_PRICE_MODULE_DECISION=price_REPLACE_ME      # Decision Engine ($19/mo)
STRIPE_PRICE_MODULE_KNOWLEDGE=price_REPLACE_ME     # Knowledge System ($15/mo)
STRIPE_PRICE_MODULE_LEVERAGE=price_REPLACE_ME      # Digital Leverage ($19/mo)
STRIPE_PRICE_MODULE_REVERSE=price_REPLACE_ME       # Reverse Engineering ($25/mo)
STRIPE_PRICE_MODULE_OFFER=price_REPLACE_ME         # Offer Generator ($15/mo)
STRIPE_PRICE_MODULE_EXECUTION=price_REPLACE_ME     # Execution Service ($29/mo)

# NOTE: Stripe redirect URLs are now computed from PUBLIC_WEB_URL automatically.
# No need to set STRIPE_CHECKOUT_SUCCESS_URL / CANCEL_URL / PORTAL_RETURN_URL.

# SECURITY — TOTP 2FA encryption at rest (Fernet AES-128)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If empty, TOTP secrets are stored in plain base32 (acceptable only for dev)
TOTP_ENCRYPTION_KEY=GENERATE_WITH_FERNET_AND_SET_HERE
TOTP_ENCRYPTION_KEY_REF=

# OPENAI (fallback LLM)
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_API_KEY_REF=

# OLLAMA
OLLAMA_CLIENT_BASE_URL=http://127.0.0.1:11434
OLLAMA_ADMIN_BASE_URL=http://127.0.0.1:11435
OLLAMA_DEFAULT_MODEL=llama3

# PRIVATE ORCHESTRATOR (admin-only scaffold, disabled by default)
PRIVATE_ORCHESTRATOR_ENABLED=false
PRIVATE_ORCHESTRATOR_UPSTREAM_URL=http://ai-orchestrator:8020
PRIVATE_ORCHESTRATOR_ALLOWED_AGENTS=operator,ghost_agency,decision_engine
NEXT_PUBLIC_PRIVATE_ORCHESTRATOR_ENABLED=false

# EMAIL (Resend — https://resend.com)
RESEND_API_KEY=re_REPLACE_ME
RESEND_API_KEY_REF=
RESEND_FROM_EMAIL=noreply@nanovia.ca
RESEND_FROM_NAME=Nanovia OS

# CORS (comma-separated, no trailing slash)
ALLOWED_ORIGINS_RAW=http://localhost:3000,http://localhost:3020
# Production (same-origin): API_BASE_URL=https://nanovia.ca ; NEXT_PUBLIC_API_URL= ; PUBLIC_WEB_URL=https://nanovia.ca ; PRIVATE_ADMIN_URL=https://admin.nanovia.ca ; ALLOWED_ORIGINS_RAW=https://nanovia.ca,https://www.nanovia.ca,https://admin.nanovia.ca

# MONITORING
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# TELEGRAM (alertes Kevin)
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# RATE LIMITING (applies per user/IP per minute)
RATE_LIMIT_PER_MINUTE=100

# ADMIN SECURITY
# Development can leave this empty. Production must set one or more CIDRs.
# Example: ADMIN_ALLOWED_IPS=203.0.113.10/32,10.0.0.0/8
ADMIN_ALLOWED_IPS=
