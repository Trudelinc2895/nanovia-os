# ============================================================
# Nanovia OS — .env.example
# cp .env.example .env  →  remplir les vraies valeurs
# JAMAIS committer .env
# ============================================================

# APP
APP_ENV=development                        # development | staging | production
APP_NAME=Nanovia OS
APP_VERSION=1.0.0
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_REGION=local

# DOMAIN
DOMAIN=nanovia.ca
ACME_EMAIL=admin@nanovia.ca
PUBLIC_IP=REPLACE_ME_PUBLIC_IP

# PORTS
API_PORT=8010
ADMIN_PORT=3020
WEB_PORT=3000
AI_ORCHESTRATOR_PORT=8020

# URLS (no trailing slash)
API_BASE_URL=http://127.0.0.1:8010
# Leave empty in production to use same-origin /api behind the reverse proxy.
NEXT_PUBLIC_API_URL=
PUBLIC_WEB_URL=http://localhost:3000       # Used for Stripe redirects and email links
PRIVATE_ADMIN_URL=http://localhost:3020
PRIVATE_ADMIN_HOST=admin.nanovia.local
AI_STATE_DIR=.runtime/nanovia-ai
AI_ADMIN_API_KEY=CHANGE_ME_LONG_RANDOM_AI_ADMIN_KEY

# DATABASE
# Dev SQLite:   sqlite+aiosqlite:///./dev.db
# Prod Postgres: postgresql+psycopg://user:pass@host:5432/dbname
POSTGRES_DB=ktmonetization
POSTGRES_USER=ktadmin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_32CHAR+
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# REDIS
# Generate password: openssl rand -hex 32
REDIS_PASSWORD=GENERATE_WITH_openssl_rand_hex_32
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
# Dev (no auth): REDIS_URL=redis://localhost:6379/0

# VAULT
SECRET_PROVIDER=auto                        # env | auto | vault
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=CHANGE_ME
VAULT_REQUEST_TIMEOUT_SECONDS=5.0

# JWT (min 32 chars — use: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE_ME_256BIT_RANDOM_32CHARS_MINIMUM
JWT_SECRET_KEY_REF=
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ISSUER=nanovia
JWT_AUDIENCE=nanovia-users

# STRIPE (renseigner via secret manager ou .env local sécurisé)
# Générer les price IDs via: python stripe/setup_stripe.py
STRIPE_PUBLIC_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_SECRET_KEY_REF=
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET_REF=
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_SECRET_KEY_REF=
TURNSTILE_PROTECT_LOGIN=true
TURNSTILE_PROTECT_REGISTER=true
TURNSTILE_PROTECT_CONTACT=true
TURNSTILE_PROTECT_BILLING=true
TURNSTILE_ALLOWED_HOSTNAMES_RAW=nanovia.ca,www.nanovia.ca

# Subscription prices (monthly + yearly)
STRIPE_PRICE_PRO_MONTHLY_ID=price_REPLACE_ME
STRIPE_PRICE_PRO_YEARLY_ID=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_MONTHLY_ID=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_YEARLY_ID=price_REPLACE_ME

# One-time purchases
STRIPE_CREDIT_PRICE_ID=price_REPLACE_ME          # credit pack (one-time)
STRIPE_CREDIT_PACK_SIZE=100                        # credits per pack

# Add-ons (one-time)
STRIPE_PRICE_ADDON_API_PACK=price_REPLACE_ME       # +500 API calls ($5)
STRIPE_PRICE_ADDON_STORAGE_10GB=price_REPLACE_ME   # +10 GB storage ($5)
STRIPE_PRICE_CREDITS_PACK=price_REPLACE_ME         # +50 credits ($4)

# Per-module à-la-carte subscriptions (monthly recurring)
# Run: python stripe/setup_stripe.py  →  copies these IDs
STRIPE_PRICE_MODULE_OPERATOR=price_REPLACE_ME      # AI Operator ($19/mo)
STRIPE_PRICE_MODULE_CONTENT=price_REPLACE_ME       # Content Cloner ($15/mo)
STRIPE_PRICE_MODULE_MICRO_SAAS=price_REPLACE_ME    # Micro-SaaS Builder ($29/mo)
STRIPE_PRICE_MODULE_GHOST=price_REPLACE_ME         # Ghost Agency ($39/mo)
STRIPE_PRICE_MODULE_DECISION=price_REPLACE_ME      # Decision Engine ($19/mo)
STRIPE_PRICE_MODULE_KNOWLEDGE=price_REPLACE_ME     # Knowledge System ($15/mo)
STRIPE_PRICE_MODULE_LEVERAGE=price_REPLACE_ME      # Digital Leverage ($19/mo)
STRIPE_PRICE_MODULE_REVERSE=price_REPLACE_ME       # Reverse Engineering ($25/mo)
STRIPE_PRICE_MODULE_OFFER=price_REPLACE_ME         # Offer Generator ($15/mo)
STRIPE_PRICE_MODULE_EXECUTION=price_REPLACE_ME     # Execution Service ($29/mo)

# NOTE: Stripe redirect URLs are now computed from PUBLIC_WEB_URL automatically.
# No need to set STRIPE_CHECKOUT_SUCCESS_URL / CANCEL_URL / PORTAL_RETURN_URL.

# SECURITY — TOTP 2FA encryption at rest (Fernet AES-128)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If empty, TOTP secrets are stored in plain base32 (acceptable only for dev)
TOTP_ENCRYPTION_KEY=GENERATE_WITH_FERNET_AND_SET_HERE
TOTP_ENCRYPTION_KEY_REF=

# OPENAI (fallback LLM)
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_API_KEY_REF=

# OLLAMA
OLLAMA_CLIENT_BASE_URL=http://127.0.0.1:11434
OLLAMA_ADMIN_BASE_URL=http://127.0.0.1:11435
OLLAMA_DEFAULT_MODEL=llama3

# PRIVATE ORCHESTRATOR (admin-only scaffold, disabled by default)
PRIVATE_ORCHESTRATOR_ENABLED=false
PRIVATE_ORCHESTRATOR_UPSTREAM_URL=http://ai-orchestrator:8020
PRIVATE_ORCHESTRATOR_ALLOWED_AGENTS=operator,ghost_agency,decision_engine
NEXT_PUBLIC_PRIVATE_ORCHESTRATOR_ENABLED=false

# EMAIL (Resend — https://resend.com)
RESEND_API_KEY=re_REPLACE_ME
RESEND_API_KEY_REF=
RESEND_FROM_EMAIL=noreply@nanovia.ca
RESEND_FROM_NAME=Nanovia OS

# CORS (comma-separated, no trailing slash)
ALLOWED_ORIGINS_RAW=http://localhost:3000,http://localhost:3020
# Production (same-origin): API_BASE_URL=https://nanovia.ca ; NEXT_PUBLIC_API_URL= ; PUBLIC_WEB_URL=https://nanovia.ca ; PRIVATE_ADMIN_URL=https://admin.nanovia.ca ; ALLOWED_ORIGINS_RAW=https://nanovia.ca,https://www.nanovia.ca,https://admin.nanovia.ca

# MONITORING
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# TELEGRAM (alertes Kevin)
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# CLOUDFLARE / OVH (infra automation only)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
OVH_ENDPOINT=ovh-ca
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
OVH_SERVICE_NAME=

# RATE LIMITING (applies per user/IP per minute)
RATE_LIMIT_PER_MINUTE=100

# ADMIN SECURITY
# Development can leave this empty. Production must set one or more CIDRs.
# Example: ADMIN_ALLOWED_IPS=203.0.113.10/32,10.0.0.0/8
ADMIN_ALLOWED_IPS=

# SCRAPING (secure, allowlist-first)
SCRAPING_ENABLED=false                       # keeps the legacy /scrape endpoint available when set true
ENABLE_SCRAPE_PROXY=false                    # enables the scalable proxy layer on top of /scrape
SCRAPING_PROXY_LAYER_ENABLED=false           # explicit alias of ENABLE_SCRAPE_PROXY
SCRAPING_REQUIRE_AUTH=false
SCRAPE_REQUIRE_AUTH=false
SCRAPING_MODE_DEFAULT=sync                   # sync | async
SCRAPE_MODE=sync
SCRAPING_STRICT_ALLOWLIST=true
SCRAPING_ALLOWLIST_RAW=example.com,news.ycombinator.com
SCRAPE_ALLOWED_DOMAINS=example.com,news.ycombinator.com
SCRAPING_BLOCK_PRIVATE_IPS=true
SCRAPE_BLOCK_PRIVATE_IPS=true
SCRAPING_ALLOWED_CONTENT_TYPES_RAW=text/html,text/plain,application/json,application/xml,text/xml
SCRAPE_ALLOWED_CONTENT_TYPES=text/html,application/json
SCRAPE_TTL_SECONDS=900                       # alias of SCRAPING_CACHE_TTL_SECONDS
SCRAPE_CACHE_TTL_SECONDS=900
SCRAPING_CACHE_TTL_SECONDS=900
SCRAPE_CACHE_STALE_TTL_SECONDS=3600
SCRAPING_CACHE_STALE_TTL_SECONDS=3600
SCRAPE_MAX_RESPONSE_BYTES=2097152
SCRAPING_MAX_RESPONSE_BYTES=2097152
SCRAPE_MAX_REDIRECTS=3
SCRAPING_MAX_REDIRECTS=3
SCRAPE_TIMEOUT_MS=15000                      # alias of SCRAPING_TIMEOUT_SECONDS in ms
SCRAPING_TIMEOUT_SECONDS=15
SCRAPE_RATE_LIMIT_DOMAIN_PER_MINUTE=30
RATE_LIMIT_MAX_PER_DOMAIN=30                 # alias of SCRAPING_RATE_LIMIT_PER_DOMAIN_PER_MIN
SCRAPING_RATE_LIMIT_PER_DOMAIN_PER_MIN=30
SCRAPE_RATE_LIMIT_CLIENT_PER_MINUTE=60
SCRAPING_RATE_LIMIT_CLIENT_PER_MIN=60
SCRAPING_CLIENT_DAILY_QUOTA=0                # 0 disables quota
SCRAPING_CLIENT_MAX_QUEUED_JOBS=0            # 0 disables per-client async queue cap
SCRAPING_DEDUPE_TTL_SECONDS=300
SCRAPE_RETRY_ATTEMPTS=3
SCRAPE_MAX_RETRIES=3                         # alias of SCRAPING_RETRY_MAX_ATTEMPTS
SCRAPING_RETRY_MAX_ATTEMPTS=3
SCRAPE_RETRY_BACKOFF_MS=1000
SCRAPING_RETRY_BACKOFF_BASE_MS=1000
SCRAPE_CIRCUIT_FAILURE_THRESHOLD=5
SCRAPING_CIRCUIT_FAIL_THRESHOLD=5
SCRAPE_CIRCUIT_RESET_TIMEOUT_MS=60000
SCRAPING_CIRCUIT_OPEN_SECONDS=60
SCRAPE_PROXY_ENABLED=false
SCRAPING_PROXY_ROTATION_ENABLED=false
SCRAPE_PROXY_URLS=
SCRAPING_PROXY_LIST_RAW=
SCRAPING_PROXY_BYPASS_DOMAINS_RAW=
SCRAPE_QUEUE_MAX_WAITING=1000
SCRAPING_QUEUE_MAX_DEPTH=1000
SCRAPE_QUEUE_CONCURRENCY=3
SCRAPING_QUEUE_CONCURRENCY=3
SCRAPE_QUEUE_JOB_TIMEOUT_MS=30000
SCRAPING_QUEUE_JOB_TIMEOUT_MS=30000
SCRAPING_JOB_TTL_SECONDS=3600
SCRAPE_FALLBACK_DIRECT_ENABLED=true
SCRAPING_FALLBACK_DIRECT_ENABLED=true
SCRAPE_REDIS_REQUIRED=false
SCRAPING_REDIS_REQUIRED=false
SCRAPING_BROWSER_POOL_SIZE=2
SCRAPING_JITTER_MIN_MS=250
SCRAPING_JITTER_MAX_MS=1500
SCRAPING_USER_AGENT=nanovia-scraper/1.0
SCRAPE_USER_AGENT=nanovia-scraper/1.0
SCRAPING_ACCEPT_LANGUAGE=fr-CA,fr;q=0.9,en;q=0.8
SCRAPE_ACCEPT_LANGUAGE=fr-CA,fr;q=0.9,en;q=0.8
SCRAPING_RUN_WORKER_IN_API=false             # true for simple deployments; false with dedicated worker
SCRAPE_METRICS_ENABLED=true
SCRAPING_METRICS_ENABLED=true
SCRAPING_FEATURE_PROXY_ENABLED=true
SCRAPING_FEATURE_BROWSER_ENABLED=true
SCRAPING_FEATURE_ASYNC_QUEUE_ENABLED=true
SCRAPING_FEATURE_CACHE_FALLBACK_ENABLED=true
SCRAPING_STEALTH_MODE=false
SCRAPING_STEALTH_HEADER_ROTATION=true
SCRAPING_STEALTH_PROFILE=chrome-windows
SCRAPE_TIMEZONE=America/Montreal
SCRAPING_STEALTH_TIMEZONE=America/Montreal
SCRAPE_VIEWPORT_WIDTH=1365
SCRAPING_STEALTH_VIEWPORT_WIDTH=1365
SCRAPE_VIEWPORT_HEIGHT=768
SCRAPING_STEALTH_VIEWPORT_HEIGHT=768
SCRAPING_PROXY_HEALTH_CHECK_INTERVAL_SECONDS=300
SCRAPING_PROXY_HEALTH_CHECK_URL=https://httpbin.org/ip
SCRAPING_WORKER_HEARTBEAT_INTERVAL_SECONDS=10
SCRAPING_WORKER_HEARTBEAT_TTL_SECONDS=30
