# ============================================================
# KT Monetization OS — .env.example
# cp .env.example .env  →  remplir les vraies valeurs
# JAMAIS committer .env
# ============================================================

# APP
APP_ENV=development                        # development | staging | production
APP_NAME=KT Monetization OS
APP_VERSION=1.0.0
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR | CRITICAL

# DOMAIN
DOMAIN=tkverse.ca
ACME_EMAIL=admin@tkverse.ca

# PORTS
API_PORT=8010
ADMIN_PORT=3020
WEB_PORT=3000
AI_ORCHESTRATOR_PORT=8020

# URLS (no trailing slash)
API_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010
PUBLIC_WEB_URL=http://127.0.0.1:3000      # Used for Stripe redirects and email links
PRIVATE_ADMIN_URL=http://127.0.0.1:3020

# DATABASE
# Dev SQLite:   sqlite+aiosqlite:///./dev.db
# Prod Postgres: postgresql+psycopg://user:pass@host:5432/dbname
POSTGRES_DB=ktmonetization
POSTGRES_USER=ktadmin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_32CHAR+
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# REDIS
REDIS_URL=redis://localhost:6379/0

# VAULT
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=CHANGE_ME

# JWT (min 32 chars — use: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE_ME_256BIT_RANDOM_32CHARS_MINIMUM
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ISSUER=tkverse
JWT_AUDIENCE=tkverse-users

# STRIPE (TEST → remplacer stripe_test_ par stripe_live_ en prod)
# Générer les price IDs via: python stripe/setup_stripe.py
STRIPE_PUBLIC_KEY=stripe_public_test_REPLACE_ME
STRIPE_SECRET_KEY=stripe_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=stripe_webhook_REPLACE_ME

# Subscription prices (monthly + yearly)
STRIPE_PRICE_PRO_MONTHLY_ID=price_REPLACE_ME
STRIPE_PRICE_PRO_YEARLY_ID=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_MONTHLY_ID=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_YEARLY_ID=price_REPLACE_ME

# One-time purchases
STRIPE_CREDIT_PRICE_ID=price_REPLACE_ME          # credit pack (one-time)
STRIPE_CREDIT_PACK_SIZE=100                        # credits per pack

# Add-ons (one-time)
STRIPE_PRICE_ADDON_API_PACK=price_REPLACE_ME       # +500 API calls ($5)
STRIPE_PRICE_ADDON_STORAGE_10GB=price_REPLACE_ME   # +10 GB storage ($5)
STRIPE_PRICE_CREDITS_PACK=price_REPLACE_ME         # +50 credits ($4)

# NOTE: Stripe redirect URLs are now computed from PUBLIC_WEB_URL automatically.
# No need to set STRIPE_CHECKOUT_SUCCESS_URL / CANCEL_URL / PORTAL_RETURN_URL.

# OPENAI (fallback LLM)
OPENAI_API_KEY=sk-REPLACE_ME

# OLLAMA
OLLAMA_CLIENT_BASE_URL=http://127.0.0.1:11434
OLLAMA_ADMIN_BASE_URL=http://127.0.0.1:11435
OLLAMA_DEFAULT_MODEL=llama3

# EMAIL (Resend — https://resend.com)
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@tkverse.ca
RESEND_FROM_NAME=KT Monetization OS

# CORS (comma-separated, no trailing slash)
ALLOWED_ORIGINS_RAW=http://localhost:3000,http://localhost:3020
# Production: ALLOWED_ORIGINS_RAW=https://tkverse.ca,https://admin.tkverse.ca

# MONITORING
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# TELEGRAM (alertes Kevin)
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# RATE LIMITING (applies per user/IP per minute)
RATE_LIMIT_PER_MINUTE=100
