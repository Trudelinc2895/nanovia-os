# ============================================================
# KT Monetization OS — .env.example
# cp .env.example .env  →  remplir les vraies valeurs
# JAMAIS committer .env
# ============================================================

# APP
APP_ENV=development
APP_NAME=KT Monetization OS
APP_VERSION=1.0.0

# DOMAIN
DOMAIN=tkverse.ca
ACME_EMAIL=admin@tkverse.ca

# PORTS
API_PORT=8010
ADMIN_PORT=3020
WEB_PORT=3000
AI_ORCHESTRATOR_PORT=8020

# URLS
API_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_API_URL=http://127.0.0.1:8010
PUBLIC_WEB_URL=http://127.0.0.1:3000
PRIVATE_ADMIN_URL=http://127.0.0.1:3020

# DATABASE
POSTGRES_DB=ktmonetization
POSTGRES_USER=ktadmin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_32CHAR+
DATABASE_URL=postgresql+psycopg://ktadmin:CHANGE_ME@localhost:5432/ktmonetization

# REDIS
REDIS_URL=redis://localhost:6379/0

# VAULT
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=CHANGE_ME

# JWT
JWT_SECRET_KEY=CHANGE_ME_256BIT_RANDOM
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ISSUER=tkverse
JWT_AUDIENCE=tkverse-users

# STRIPE (TEST → remplacer sk_test_ par sk_live_ en prod)
STRIPE_PUBLIC_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_PRO_MONTHLY_ID=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_MONTHLY_ID=price_REPLACE_ME
STRIPE_CHECKOUT_SUCCESS_URL=https://tkverse.ca/dashboard?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://tkverse.ca/#pricing
STRIPE_PORTAL_RETURN_URL=https://tkverse.ca/dashboard

# OPENAI (fallback LLM)
OPENAI_API_KEY=sk-REPLACE_ME

# OLLAMA
OLLAMA_CLIENT_BASE_URL=http://127.0.0.1:11434
OLLAMA_ADMIN_BASE_URL=http://127.0.0.1:11435
OLLAMA_DEFAULT_MODEL=llama3

# EMAIL
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME@gmail.com
SMTP_PASSWORD=REPLACE_ME
EMAIL_FROM=noreply@tkverse.ca

# MONITORING
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# TELEGRAM (alertes Kevin)
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# SECURITY
ALLOWED_ORIGINS=https://tkverse.ca,https://admin.tkverse.ca
RATE_LIMIT_PER_MINUTE=100
