# KT Monetization OS — Caddyfile
# MODE: HTTP-only (IP fallback until DNS is configured)
# Switch to Caddyfile.https once tkverse.ca DNS resolves

:80 {
    # API — strip /api prefix before proxying
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:8010
        header X-Frame-Options DENY
        header X-Content-Type-Options nosniff
    }

    handle /health {
        reverse_proxy api:8010
    }

    handle {
        reverse_proxy web:3000
        encode gzip
        header X-Frame-Options DENY
        header X-Content-Type-Options nosniff
        header Referrer-Policy strict-origin-when-cross-origin
    }
}

# Admin on dedicated port (HTTP-only)
:8020 {
    reverse_proxy admin:3020
}

# Grafana on dedicated port — listens on 3000 internally
:9091 {
    reverse_proxy grafana:3000
}


