{
    servers {
        trusted_proxies static private_ranges
    }
    email {$ACME_EMAIL:admin@localhost}
}

(security_headers) {
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-origin"
        Origin-Agent-Cluster "?1"
        X-Permitted-Cross-Domain-Policies "none"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.stripe.com https://r.stripe.com; frame-src https://js.stripe.com https://hooks.stripe.com; form-action 'self' https://checkout.stripe.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;"
        -Server
        -X-Powered-By
    }
}

(block_attackers) {
    @scanners header_regexp User-Agent "(nikto|sqlmap|masscan|nmap|zgrab|dirbuster|gobuster|wfuzz|hydra|medusa|metasploit|burpsuite|acunetix|nessus|openvas|w3af|python-requests/2\.[0-2])"
    respond @scanners 403

    @sqli path_regexp "(union.*select|select.*from|drop.*table|insert.*into|exec.*\()"
    respond @sqli 403

    @path_traversal path_regexp "(\.\./|\.\.\\\\|%2e%2e)"
    respond @path_traversal 403

    @bad_methods not method GET POST PUT PATCH DELETE OPTIONS HEAD
    respond @bad_methods 405
}

(admin_ip_allow) {
    @not_allowed not remote_ip {$ADMIN_ALLOWED_IP}
    respond @not_allowed 403
}

# ── Public same-domain site ─────────────────────────────────────────────────
{$DOMAIN:nanovia.ca}, {$WWW_DOMAIN:www.nanovia.ca} {
    import security_headers
    import block_attackers

    handle /api/* {
        reverse_proxy api:8010
    }

    handle /metrics {
        reverse_proxy api:8010
    }

    handle /health {
        reverse_proxy api:8010
    }

    handle {
        reverse_proxy web:3000
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}

# Raw-IP bootstrap lives in Caddyfile.ip. The domain Caddyfile must stay valid
# even when PUBLIC_IP is unset so deploy tooling can validate it safely.
