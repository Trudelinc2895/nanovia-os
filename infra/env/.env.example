# Nanovia OS — Production environment template
# Public OVH VPS stack. For isolated staging, use infra/env/.env.staging.example.
# Copy to .env.production (or .env on the production VPS) and fill in real values.
# NEVER commit populated env files.

# App
APP_ENV=production
APP_NAME=Nanovia OS
APP_VERSION=1.0.0
APP_RUNTIME_ENV_FILE=../.env.production
SECRET_PROVIDER=auto
DOMAIN=nanovia.ca
ACME_EMAIL=admin@nanovia.ca
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET_KEY_REF=
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
LOG_LEVEL=INFO
PUBLIC_IP=REPLACE_ME_PUBLIC_IP

# Database
POSTGRES_DB=ktmonetization
POSTGRES_USER=ktadmin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql+psycopg://ktadmin:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/ktmonetization

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://redis:6379/0

# Vault (optional managed secret backend)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=CHANGE_ME
VAULT_REQUEST_TIMEOUT_SECONDS=5.0

# OpenAI
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_API_KEY_REF=

# Stripe
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_SECRET_KEY_REF=
STRIPE_PUBLIC_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET_REF=
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_SECRET_KEY_REF=
TURNSTILE_PROTECT_LOGIN=true
TURNSTILE_PROTECT_REGISTER=true
TURNSTILE_PROTECT_CONTACT=true
TURNSTILE_PROTECT_BILLING=true
TURNSTILE_ALLOWED_HOSTNAMES_RAW=nanovia.ca,www.nanovia.ca
STRIPE_PRICE_PRO_MONTHLY_ID=price_...
STRIPE_PRICE_PRO_YEARLY_ID=price_...
STRIPE_PRICE_BUSINESS_MONTHLY_ID=price_...
STRIPE_PRICE_BUSINESS_YEARLY_ID=price_...
STRIPE_CREDIT_PRICE_ID=price_...
STRIPE_CREDIT_PACK_SIZE=10
STRIPE_PRICE_ADDON_API_PACK=price_...
STRIPE_PRICE_ADDON_STORAGE_10GB=price_...
STRIPE_PRICE_CREDITS_PACK=price_...
STRIPE_PRICE_MODULE_OPERATOR=price_...
STRIPE_PRICE_MODULE_CONTENT=price_...
STRIPE_PRICE_MODULE_MICRO_SAAS=price_...
STRIPE_PRICE_MODULE_GHOST=price_...
STRIPE_PRICE_MODULE_DECISION=price_...
STRIPE_PRICE_MODULE_KNOWLEDGE=price_...
STRIPE_PRICE_MODULE_LEVERAGE=price_...
STRIPE_PRICE_MODULE_REVERSE=price_...
STRIPE_PRICE_MODULE_OFFER=price_...
STRIPE_PRICE_MODULE_EXECUTION=price_...

# Email
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
RESEND_API_KEY_REF=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 2FA secret encryption (required in production)
TOTP_ENCRYPTION_KEY=GENERATE_WITH_FERNET_AND_SET_HERE
TOTP_ENCRYPTION_KEY_REF=

# URLs
API_BASE_URL=https://nanovia.ca
NEXT_PUBLIC_API_URL=https://nanovia.ca
PUBLIC_WEB_URL=https://nanovia.ca
PRIVATE_ADMIN_URL=https://admin.nanovia.ca
PRIVATE_ADMIN_HOST=admin.nanovia.ca
AI_STATE_DIR=/var/lib/nanovia-ai
AI_ADMIN_API_KEY=CHANGE_ME_LONG_RANDOM_AI_ADMIN_KEY
ADMIN_ALLOWED_IP=REPLACE_WITH_YOUR_VPS_IP/32
ADMIN_ALLOWED_IPS=REPLACE_WITH_YOUR_VPS_IP/32

# CORS
ALLOWED_ORIGINS_RAW=https://nanovia.ca,https://www.nanovia.ca,https://admin.nanovia.ca

# Monitoring
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Scraping
SCRAPING_REQUIRE_AUTH=false
SCRAPE_REQUIRE_AUTH=false
SCRAPE_MODE=sync
SCRAPE_ALLOWED_DOMAINS=
SCRAPE_BLOCK_PRIVATE_IPS=true
SCRAPE_CACHE_TTL_SECONDS=900
SCRAPE_CACHE_STALE_TTL_SECONDS=3600
SCRAPE_RATE_LIMIT_DOMAIN_PER_MINUTE=30
SCRAPE_RATE_LIMIT_CLIENT_PER_MINUTE=60
SCRAPE_QUEUE_MAX_WAITING=1000
SCRAPE_QUEUE_CONCURRENCY=3
SCRAPE_QUEUE_JOB_TIMEOUT_MS=30000
SCRAPE_RETRY_ATTEMPTS=3
SCRAPE_RETRY_BACKOFF_MS=1000
SCRAPE_CIRCUIT_FAILURE_THRESHOLD=5
SCRAPE_CIRCUIT_RESET_TIMEOUT_MS=60000
SCRAPE_ALLOWED_CONTENT_TYPES=text/html,application/json
SCRAPE_USER_AGENT=nanovia-scraper/1.0
SCRAPE_ACCEPT_LANGUAGE=fr-CA,fr;q=0.9,en;q=0.8
SCRAPE_TIMEZONE=America/Montreal
SCRAPE_VIEWPORT_WIDTH=1365
SCRAPE_VIEWPORT_HEIGHT=768
SCRAPE_PROXY_ENABLED=false
SCRAPE_PROXY_URLS=
SCRAPE_FALLBACK_DIRECT_ENABLED=true
SCRAPE_REDIS_REQUIRED=false
SCRAPE_METRICS_ENABLED=true
SCRAPING_STEALTH_MODE=false
SCRAPING_STEALTH_HEADER_ROTATION=true
SCRAPING_STEALTH_PROFILE=chrome-windows
SCRAPING_STEALTH_TIMEZONE=UTC
SCRAPING_STEALTH_VIEWPORT_WIDTH=1366
SCRAPING_STEALTH_VIEWPORT_HEIGHT=768
SCRAPING_PROXY_HEALTH_CHECK_INTERVAL_SECONDS=300
SCRAPING_PROXY_HEALTH_CHECK_URL=https://httpbin.org/ip
SCRAPING_WORKER_HEARTBEAT_INTERVAL_SECONDS=10
SCRAPING_WORKER_HEARTBEAT_TTL_SECONDS=30
SCRAPING_CLIENT_MAX_QUEUED_JOBS=0
SCRAPING_PROXY_BYPASS_DOMAINS_RAW=
SCRAPING_FEATURE_PROXY_ENABLED=true
SCRAPING_FEATURE_BROWSER_ENABLED=true
SCRAPING_FEATURE_ASYNC_QUEUE_ENABLED=true
SCRAPING_FEATURE_CACHE_FALLBACK_ENABLED=true
SCRAPING_RUN_WORKER_IN_API=false

# Infrastructure
APP_REGION=us-east-1
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
OVH_ENDPOINT=ovh-ca
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=
OVH_SERVICE_NAME=

# Feature flags
CHAOS_ENABLED=false
