# Nanovia OS — Staging environment template
# Single-host OVH staging stays isolated from production:
# - deploy to a separate path/project name
# - app services bind to loopback-only high ports via infra/docker-compose.staging.yml
# - Caddy is intentionally not started for staging on the shared VPS
#
# Copy to .env.staging on the VPS and fill in safe non-production values.
# NEVER commit populated env files.

# App
APP_ENV=staging
APP_NAME=Nanovia OS (staging)
APP_VERSION=1.0.0
APP_RUNTIME_ENV_FILE=../.env.staging
ACME_EMAIL=admin@nanovia.ca
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
LOG_LEVEL=INFO
APP_REGION=us-east-1-staging
DOMAIN=staging.nanovia.local
PUBLIC_IP=REPLACE_ME_PUBLIC_IP

# Isolated loopback-only publish ports (use SSH tunnels to access)
STAGING_BIND_ADDRESS=127.0.0.1
STAGING_WEB_PORT=13000
STAGING_ADMIN_PORT=13020
STAGING_API_PORT=18010
STAGING_AI_PORT=18020

# Database / Redis
POSTGRES_DB=ktmonetization
POSTGRES_USER=ktadmin
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
DATABASE_URL=postgresql+psycopg://ktadmin:CHANGE_ME_STAGING_DB_PASSWORD@postgres:5432/ktmonetization
REDIS_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STAGING_REDIS_PASSWORD@redis:6379/0

# Non-public staging URLs (match the SSH-tunnel ports above)
API_BASE_URL=http://127.0.0.1:18010
NEXT_PUBLIC_API_URL=http://127.0.0.1:18010
PUBLIC_WEB_URL=http://127.0.0.1:13000
PRIVATE_ADMIN_URL=http://127.0.0.1:13020
ALLOWED_ORIGINS_RAW=http://127.0.0.1:13000,http://127.0.0.1:13020

# Use test-only integrations in staging
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY_ID=price_...
STRIPE_PRICE_PRO_YEARLY_ID=price_...
STRIPE_PRICE_BUSINESS_MONTHLY_ID=price_...
STRIPE_PRICE_BUSINESS_YEARLY_ID=price_...
STRIPE_CREDIT_PRICE_ID=price_...
STRIPE_CREDIT_PACK_SIZE=10
RESEND_API_KEY=re_...
TOTP_ENCRYPTION_KEY=GENERATE_WITH_FERNET_AND_SET_HERE
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin access + monitoring
ADMIN_ALLOWED_IP=127.0.0.1/32
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
SCRAPING_WORKER_HEARTBEAT_INTERVAL_SECONDS=10
SCRAPING_WORKER_HEARTBEAT_TTL_SECONDS=30
